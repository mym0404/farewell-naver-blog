{
  "name": "farewell-naver-blog",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "NODE_ENV=development bun --watch src/Server.ts",
    "start": "pnpm build:ui && bun src/Server.ts",
    "build:ui": "vite build",
    "build:server": "tsc -p tsconfig.json",
    "build": "pnpm build:ui && pnpm build:server",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check:unused": "bun scripts/check-unused.ts",
    "test": "vitest run --configLoader runner --silent",
    "test:coverage": "vitest run --configLoader runner --silent --coverage",
    "test:parser-blocks": "vitest run --config vitest.parser-blocks.config.ts --silent --coverage",
    "test:offline": "vitest run --configLoader runner --silent",
    "test:network": "pnpm build:ui && bun tests/e2e/run-ui-live-resume-export.ts && bun tests/e2e/run-ui-live-resume-export.ts --case se2-table && bun tests/e2e/run-ui-live-upload.ts",
    "test:network:resume-export": "bun tests/e2e/run-ui-live-resume-export.ts",
    "test:network:resume-export:se2-table": "bun tests/e2e/run-ui-live-resume-export.ts --case se2-table",
    "test:network:upload": "pnpm build:ui && bun tests/e2e/run-ui-live-upload.ts",
    "smoke:ui": "pnpm build:ui && bun tests/e2e/run-ui-smoke-suite.ts",
    "check:local": "pnpm typecheck && pnpm test:offline",
    "check:full": "pnpm check:local && pnpm smoke:ui"
  },
  "dependencies": {
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-slot": "^1.2.4",
    "@remixicon/react": "^4.9.0",
    "cheerio": "^1.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "domhandler": "^5.0.3",
    "piclist": "2.3.5",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "turndown": "^7.2.0",
    "turndown-plugin-gfm": "^1.0.2",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^24.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^3.2.4",
    "jsdom": "^26.1.0",
    "knip": "6.9.0",
    "playwright": "^1.59.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.8",
    "vitest": "^3.2.4"
  }
}
